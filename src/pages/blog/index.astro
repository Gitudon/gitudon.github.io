---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { TEST_IMG } from "../../consts";
import { getCollection } from "astro:content";
import FormattedDate from "../../components/FormattedDate.astro";

const posts = (await getCollection("blog")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={"Udon's Blog"} description={"Udon's Blog Page"} />
		<style>
			main {
				width: 960px;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}

			/* 最新記事（1番目のli）のスタイル */
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
				display: flex;
				justify-content: center;
			}
			ul li:first-child a {
				width: calc(50% - 1rem);
			}
			ul li:first-child .title {
				font-size: 1.5rem;
			}
			ul li img {
				width: 100%;
				aspect-ratio: 4 / 3;
				object-fit: fill;
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			ul li a {
				display: block;
				text-align: center;
			}

			/* 【変更】各要素の間隔を詰めるため、下マージンを微調整 */
			.title {
				margin: 0 0 0.2rem 0; /* 下にほんの少しだけ隙間を開ける */
				color: rgb(var(--black));
				line-height: 1.2;
			}
			/* 【追加】カテゴリのスタイル（マージンを消して黒色にする） */
			.category {
				margin: 0 0 0.2rem 0; /* 下にほんの少しだけ隙間を開ける */
				color: rgb(var(--black));
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
			}

			/* ホバー時の色変更にカテゴリも含める */
			ul li a:hover h4,
			ul li a:hover .category,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			/* スマホ表示（レスポンシブ）の設定 */
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child a {
					width: 100%;
				}
				ul li:first-child .title {
					font-size: 1.5em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={"/blog/" + post.id + "/"}>
									<img
										src={post.data.heroImage || TEST_IMG}
										alt=""
									/>
									<h4 class="title">
										{post.data.title || "No title"}
									</h4>
									{/* 【変更】class="category" を追加 */}
									<p class="category">
										Category:
										{post.data.category || "その他"}
									</p>
									<p class="date">
										<FormattedDate
											date={
												post.data.pubDate || new Date()
											}
										/>
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
