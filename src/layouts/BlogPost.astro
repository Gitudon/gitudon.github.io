---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import { SITE_DESCRIPTION, TEST_IMG } from "../consts";

type Props = CollectionEntry<"blog">["data"];
const { title, description, category, pubDate, updatedDate, heroImage } =
	Astro.props;
---

<html lang="ja">
	<head>
		<BaseHead title={title} description={description || SITE_DESCRIPTION} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 20%;
				margin-left: calc(40%);
			}
			.hero-image img {
				display: block;
				width: 100%;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
				font-size: 1.5em;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			p {
				font-color: #000000;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{(<img src={heroImage || TEST_IMG} alt="" />)}
				</div>
				<div class="prose">
					<div class="title">
						<h1>{title}</h1>
						<p>Category: {category || "その他"}</p>
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										( Last updated on{" "}
										<FormattedDate date={updatedDate} />)
									</div>
								)
							}
						</div>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
